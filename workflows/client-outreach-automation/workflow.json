    {
      "parameters": {
        "jsCode": "// Keep only rows that:\n//   - status == 'sent' (no reply yet, no bounce)\n//   - follow_up_due_date <= now\n//   - follow_up_sent_at is empty\nconst now = new Date();\nconst out = [];\nfor (const item of $input.all()) {\n  const r = item.json;\n  if (!r) continue;\n  if (String(r.status || '').toLowerCase() !== 'sent') continue;\n  if (r.follow_up_sent_at && String(r.follow_up_sent_at).trim() !== '') continue;\n  const due = r.follow_up_due_date ? new Date(r.follow_up_due_date) : null;\n  if (!due || isNaN(due.getTime())) continue;\n  if (due > now) continue;\n  out.push({ json: r });\n}\nreturn out;"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
