    {
      "parameters": {
        "jsCode": "// Parse the Telegram brief into structured search params.\n// Works for both Telegram triggers. The source_bot field is added right after each trigger\n// so the final notification can be routed back through the same Telegram account.\n\nconst incoming = $input.first().json;\nconst msg = incoming.message || {};\nconst raw = (msg.text || '').trim();\n\nif (!raw) {\n  throw new Error('Empty Telegram message \u2014 send a brief like \"5 dental clinics in Zagreb\".');\n}\n\nconst countMatch = raw.match(/(?:count\\s*=\\s*)?(\\b\\d{1,2}\\b)/i);\nconst count = Math.min(parseInt(countMatch?.[1] || '5', 10), 15); // hard cap 15/run\n\nconst inMatch = raw.match(/\\b(?:in|across|throughout)\\s+([A-Za-z\u010d\u0107\u017e\u0161\u0111\u010c\u0106\u017d\u0160\u0110 ,]+?)(?:\\s+\\d|$)/i);\nconst location = inMatch?.[1]?.trim() || 'worldwide';\n\nreturn [{\n  json: {\n    raw_brief: raw,\n    count,\n    location,\n    requested_at: new Date().toISOString(),\n    chat_id: msg.chat?.id,\n    telegram_user_id: msg.from?.id,\n    telegram_username: msg.from?.username || '',\n    telegram_first_name: msg.from?.first_name || '',\n    source_bot: incoming.source_bot || 'telegram_1'\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -208,
        -272
      ],
      "id": "6fd74d82-ecca-4b05-b36d-8af7c90a5d17",
      "name": "Parse Brief"
    },
