    {
      "parameters": {
        "jsCode": "// Drop any lead whose email is already in Aggregate Sent Emails.\nconst sent = new Set(\n  ($('Aggregate Sent Emails').first().json.all_sent_emails || []).map(e => String(e).toLowerCase())\n);\n\nconst out = [];\nfor (const item of $input.all()) {\n  const lead = item.json;\n  const email = String(lead.email || '').trim().toLowerCase();\n  if (!email) continue;            // discard leads without an email\n  if (sent.has(email)) continue;   // already contacted before\n  out.push({ json: lead });\n}\nreturn out;"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
